#!/usr/bin/env python3
"""
DR Core Lite — SQLite DB Store

Stores parsed JSON artifacts into SQLite.
"""

from dr_core_lite.helpers.paths import PARSED_DIR, DB_FILE
import os, json, sqlite3
from datetime import datetime

def init_db():
    """Initialize DB tables if they don't exist."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    c.execute("""
        CREATE TABLE IF NOT EXISTS runs (
            run_id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT
        )
    """)
    c.execute("""
        CREATE TABLE IF NOT EXISTS interfaces (
            run_id INTEGER,
            index TEXT,
            name TEXT,
            ipv4 TEXT,
            ipv6 TEXT,
            FOREIGN KEY(run_id) REFERENCES runs(run_id)
        )
    """)
    c.execute("""
        CREATE TABLE IF NOT EXISTS wireless (
            run_id INTEGER,
            name TEXT,
            mac TEXT,
            type TEXT,
            txpower TEXT,
            FOREIGN KEY(run_id) REFERENCES runs(run_id)
        )
    """)
    c.execute("""
        CREATE TABLE IF NOT EXISTS radio_state (
            run_id INTEGER,
            index TEXT,
            name TEXT,
            soft_blocked TEXT,
            hard_blocked TEXT,
            FOREIGN KEY(run_id) REFERENCES runs(run_id)
        )
    """)
    c.execute("""
        CREATE TABLE IF NOT EXISTS connections (
            run_id INTEGER,
            device TEXT,
            type TEXT,
            state TEXT,
            connection TEXT,
            FOREIGN KEY(run_id) REFERENCES runs(run_id)
        )
    """)
    c.execute("""
        CREATE TABLE IF NOT EXISTS driver_info (
            run_id INTEGER,
            key TEXT,
            value TEXT,
            FOREIGN KEY(run_id) REFERENCES runs(run_id)
        )
    """)
    conn.commit()
    conn.close()

def store_json(parsed_file, table_name, run_id):
    """Store JSON file into a table."""
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    with open(parsed_file, "r") as f:
        data = json.load(f)

    # driver_info is a dict, others are lists
    if isinstance(data, dict):
        for k, v in data.items():
            c.execute(f"INSERT INTO {table_name} (run_id, key, value) VALUES (?, ?, ?)", (run_id, k, v))
    elif isinstance(data, list):
        for row in data:
            cols = ", ".join(row.keys())
            placeholders = ", ".join("?" for _ in row)
            values = tuple(row.values())
            c.execute(f"INSERT INTO {table_name} (run_id, {cols}) VALUES (?, {placeholders})", (run_id, *values))
    conn.commit()
    conn.close()

def run_db_store():
    os.makedirs(PARSED_DIR, exist_ok=True)
    os.makedirs(os.path.dirname(DB_FILE), exist_ok=True)
    init_db()
    conn = sqlite3.connect(DB_FILE)
    c = conn.cursor()
    timestamp = datetime.utcnow().isoformat()
    c.execute("INSERT INTO runs (timestamp) VALUES (?)", (timestamp,))
    run_id = c.lastrowid
    conn.commit()
    conn.close()

    artifact_map = {
        "interfaces.json": "interfaces",
        "wireless.json": "wireless",
        "radio_state.json": "radio_state",
        "connections.json": "connections",
        "driver_info.json": "driver_info"
    }

    for filename, table in artifact_map.items():
        path = os.path.join(PARSED_DIR, filename)
        if os.path.exists(path):
            store_json(path, table, run_id)

    return run_id

if __name__ == "__main__":
    rid = run_db_store()
    print(f"[+] Stored run_id {rid} into database.")
